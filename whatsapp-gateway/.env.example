# ---- HTTP (health/status detras de nginx) ----
PORT=8787
# Token para proteger /status (Authorization: Bearer <token>). /health queda abierto.
GATEWAY_TOKEN=

# ---- Comportamiento ----
# Lada por defecto cuando el telefono trae 10 digitos.
DEFAULT_COUNTRY_CODE=52
# Intervalo del barrido de la cola (ms).
SWEEP_INTERVAL_MS=15000
# Reintentos por mensaje antes de marcarlo como fallido.
MAX_ATTEMPTS=3
# Nivel de log: trace|debug|info|warn|error
LOG_LEVEL=info
# Imprimir el QR tambien en la terminal (util la primera vez).
PRINT_QR_TERMINAL=true
